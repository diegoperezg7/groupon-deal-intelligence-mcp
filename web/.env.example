# Web demo configuration. Copy to .env (one level up from web/, at the repo
# root) and fill in your values. This file documents only the keys that the
# web subproject CONSUMES — they all live in the same root .env as the MCP
# server's config so the whole project shares one place for secrets.

# --- LLM provider (the chat assistant) ---
# Default is xAI Grok. The same code works against any OpenAI-compatible
# gateway (OpenAI direct, OpenRouter, Azure deployments).
LLM_PROVIDER=openai
LLM_API_KEY=xai-your-grok-key-here
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4-1-fast-non-reasoning

# --- BFF / web server ---
WEB_PORT=3000

# --- MCP server endpoint the BFF will talk to ---
# When using docker compose, override to http://mcp:3333/mcp
MCP_URL=http://localhost:3333/mcp
