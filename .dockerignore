# Secrets — defence in depth. The Dockerfiles use specific COPY paths so
# .env would not reach an image anyway, but this is the belt-and-braces.
.env
.env.local
.env.*.local
!.env.example

# Git
.git/
.gitignore
.gitattributes
.githooks/

# Node / TypeScript build artefacts
node_modules/
web/node_modules/
dist/
build/
web/dist/
web/.vite/
*.tsbuildinfo
.npm/
.yarn/
yarn-error.log
npm-debug.log*
pnpm-debug.log*

# Python build artefacts
ingestion/.venv/
ingestion/__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Tests + coverage (the runtime images don't need them)
coverage/
.nyc_output/
tests/
web/tests/

# Local data (regenerated by `ingest` inside the image)
data/deals.sqlite
data/deals.sqlite-shm
data/deals.sqlite-wal
data/raw/
ingestion/data/raw/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Logs
logs/
*.log

# Tooling caches
.turbo/
.cache/

# Claude / local planning artefacts
.claude/
