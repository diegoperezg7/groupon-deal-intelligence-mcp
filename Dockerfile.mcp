# MCP server runtime image.
#
# This image only ships the TypeScript runtime — no scraping, no Python.
# Mount `data/deals.sqlite` from the host so the container reads an
# already-populated catalogue. Run a separate ingest step (see
# Dockerfile.ingest or `python -m groupon_ingest`) to (re)populate.

FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* tsconfig.json tsup.config.ts ./
RUN npm ci
COPY src ./src
RUN npm run build

FROM node:22-alpine AS runtime
RUN apk add --no-cache tini
WORKDIR /app
ENV NODE_ENV=production
ENV SQLITE_PATH=/data/deals.sqlite
COPY --from=deps /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY package.json ./
# Anyone mounting -v ./data:/data will satisfy SQLITE_PATH
VOLUME ["/data"]

# stdio transport is the default for MCP servers — use docker exec -i
# or invoke via the Claude Desktop config. For Streamable HTTP set
# MCP_TRANSPORT=http and expose 3333.
EXPOSE 3333

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "dist/mcp/server.js"]
